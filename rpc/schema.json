{
  "remote_session": {
    "command": {
      "argv": [
        "rpc-serve-v1",
        "service_id"
      ],
      "executable": "synckitd"
    },
    "hello": {
      "encoding": "uint32be-length-prefixed-bytes",
      "nonce_bytes": 32
    }
  },
  "operations": {
    "synckit.rpc.call": {
      "request": {
        "encoding": "json",
        "fields": {
          "method": "string|required",
          "params": "object|null|required"
        }
      },
      "response": {
        "encoding": "json",
        "fields": {
          "error": "string|optional",
          "ok": "boolean|required",
          "result": "json|null|required"
        }
      }
    },
    "synckit.rpc.runtime.health": {
      "request": {
        "encoding": "empty"
      },
      "response": {
        "encoding": "json",
        "fields": {
          "busy": "boolean|required",
          "draining": "boolean|required",
          "pid": "integer|required",
          "process_generation": "string|required",
          "ready": "boolean|required",
          "runtime_build": "string|required",
          "runtime_protocol": "integer|required",
          "state": "string|required"
        }
      }
    }
  },
  "suite": "com.yasyf.synckit.rpc",
  "version": 1
}
