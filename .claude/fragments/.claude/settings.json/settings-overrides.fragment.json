{
  "extraKnownMarketplaces": {
    "captain-hook": {
      "source": {
        "source": "github",
        "repo": "yasyf/captain-hook"
      }
    }
  },
  "enabledPlugins": {
    "captain-hook@captain-hook": true
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PermissionRequest"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook review run",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run SessionStart --async",
            "async": true
          }
        ]
      }
    ]
  }
}
